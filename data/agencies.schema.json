{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agency Directory",
  "description": "List of agencies that accept speeding concern reports",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "email", "jurisdiction", "state"],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Full name of the agency"
      },
      "email": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[^@]+@[^@]+\\.[^@]+$",
        "description": "Email address for speeding concerns"
      },
      "jurisdiction": {
        "type": "string",
        "enum": ["city", "county", "state", "regional"],
        "description": "Jurisdiction level of the agency"
      },
      "state": {
        "type": "string",
        "pattern": "^[A-Z]{2}$",
        "description": "Two-letter US state abbreviation"
      },
      "city": {
        "type": "string",
        "description": "City name (required for city-level agencies)"
      },
      "county": {
        "type": "string",
        "description": "County name (required for county-level agencies)"
      },
      "website": {
        "type": "string",
        "pattern": "^https?://",
        "description": "Agency website URL"
      },
      "notes": {
        "type": "string",
        "description": "Submission tips or requirements"
      }
    },
    "additionalProperties": false,
    "allOf": [
      {
        "if": {
          "properties": { "jurisdiction": { "const": "city" } }
        },
        "then": {
          "required": ["city"]
        }
      },
      {
        "if": {
          "properties": { "jurisdiction": { "const": "county" } }
        },
        "then": {
          "required": ["county"]
        }
      }
    ]
  }
}
